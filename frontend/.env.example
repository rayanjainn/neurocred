# Frontend API mode toggle
# true  -> use in-browser/frontend mock data (no backend required)
# false -> call existing backend API via NEXT_PUBLIC_API_URL
NEXT_PUBLIC_USE_MOCK=true

# Only used when NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: simulate API latency in mock mode (ms)
NEXT_PUBLIC_MOCK_DELAY_MS=120
